theme = Vague
#theme = Rose Pine
#config-file = ~/.config/ghostty/themes/nightfly
#config-file = ~/.config/ghostty/themes/mayhem
background-opacity = 1.0
#background = #000000

window-colorspace = "display-p3"
#window-decoration = false
window-padding-balance = true
window-save-state = always

font-family = Hack Nerd Font Mono
font-size = 20

shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = true

window-padding-x = 5
window-padding-y = 0 

macos-titlebar-style = hidden

copy-on-select = clipboard

#quick-terminal-animation-duration = 0
quick-terminal-screen = macos-menu-bar 

keybind = global:cmd+backquote=toggle_quick_terminal

macos-non-native-fullscreen = padded-notch

# Send Cmd+number to tmux as Alt+number so tmux can select windows.
keybind = super+digit_1=esc:1
keybind = super+1=esc:1
keybind = super+digit_2=esc:2
keybind = super+2=esc:2
keybind = super+digit_3=esc:3
keybind = super+3=esc:3
keybind = super+digit_4=esc:4
keybind = super+4=esc:4
keybind = super+digit_5=esc:5
keybind = super+5=esc:5
keybind = super+digit_6=esc:6
keybind = super+6=esc:6
keybind = super+digit_7=esc:7
keybind = super+7=esc:7
keybind = super+digit_8=esc:8
keybind = super+8=esc:8
keybind = super+digit_9=esc:9
keybind = super+9=esc:9
keybind = super+digit_0=esc:0
keybind = super+0=esc:0

# Send Cmd+h/j/k/l to tmux as Alt+h/j/k/l so tmux can select panes.
keybind = super+h=esc:h
keybind = super+j=esc:j
keybind = super+k=esc:k
keybind = super+l=esc:l
