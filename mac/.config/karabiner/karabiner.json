{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Use Ctrl as Cmd for copy/paste in non-terminal apps",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.mitchellh\\.ghostty$",
                                            "^com\\.apple\\.Terminal$",
                                            "^com\\.github\\.wez\\.wezterm$",
                                            "^net\\.kovidgoyal\\.kitty$"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["control"] }
                                },
                                "to": [
                                    {
                                        "key_code": "c",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.mitchellh\\.ghostty$",
                                            "^com\\.apple\\.Terminal$",
                                            "^com\\.github\\.wez\\.wezterm$",
                                            "^net\\.kovidgoyal\\.kitty$"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "v",
                                    "modifiers": { "mandatory": ["control"] }
                                },
                                "to": [
                                    {
                                        "key_code": "v",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Option+Shift+Q -> Command+Q (quit app)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "q",
                                    "modifiers": {
                                        "mandatory": ["option", "shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "q",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Option+Q -> Command+W (close window)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "q",
                                    "modifiers": {
                                        "mandatory": ["option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "w",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Tab as Hyper when held",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "tab",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_option",
                                        "lazy": true
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "tab" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Launch apps",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "return_or_enter",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/kitty.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open -a Finder" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "i",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Firefox.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Zathura.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "o",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/LibreOffice.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "e",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Emacs.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "w",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Brave Browser.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "g",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/ChatGPT.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "p",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "/bin/zsh -lc 'rmpc togglepause'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": { "mandatory": ["left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Telegram.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "CAPSLOCK as ESC when tapped and CTRL when held",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": {
                                    "basic.to_if_alone_timeout_milliseconds": 150,
                                    "basic.to_if_held_down_threshold_milliseconds": 150
                                },
                                "to": [{ "key_code": "left_control" }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 45915,
                        "vendor_id": 1133
                    },
                    "ignore": false
                }
            ],
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}